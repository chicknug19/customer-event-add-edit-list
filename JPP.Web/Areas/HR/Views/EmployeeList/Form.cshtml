@section Scripts {
    <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
    <script>
        (function ($) {
            function setSubmitMode(mode) {
                $('#SubmitMode').val(mode || 'Save');
            }

            function setSavingState(isSaving) {
                var $buttons = $('#employeeForm button[type="submit"]');
                $buttons.prop('disabled', isSaving);
                $('.employee-save-spinner').toggleClass('d-none', !isSaving);
                $('.employee-save-icon').toggleClass('d-none', isSaving);
            }

            function syncTimeTableRow($row) {
                var isWorking = $row.find('.time-working-check').is(':checked');
                $row.find('.time-row-input').prop('disabled', !isWorking || @Model.IsReadOnly.ToString().ToLowerInvariant());
            }

            function syncDutyRow($row) {
                var onDuty = $row.find('.duty-check').is(':checked');
                var isReadOnly = @Model.IsReadOnly.ToString().ToLowerInvariant();
                $row.find('.duty-remark').prop('disabled', onDuty || isReadOnly);

                if (onDuty) {
                    $row.find('.duty-remark').val('');
                }
            }

            function syncContractEnd() {
                var checked = $('#contractEndCheckbox').is(':checked');
                $('.contract-end-input').prop('disabled', !checked || @Model.IsReadOnly.ToString().ToLowerInvariant());
            }

            function showCustomTimeError(message) {
                $('#customTimeError').text(message || '').toggleClass('d-none', !message);
            }

            function reloadCustomTimeTable() {
                var employeeId = $('#customEmployeeId').val();

                if (!employeeId || parseInt(employeeId, 10) <= 0) {
                    return;
                }

                $.get('@Url.Action("GetCustomTimeTables", "EmployeeList", new { area = "HR" })', {
                    employeeId: employeeId
                }).done(function (result) {
                    if (!result || result.statusCode !== 200) {
                        showCustomTimeError(result && result.statusMessage ? result.statusMessage : 'Failed to load custom time table.');
                        return;
                    }

                    var rows = '';
                    var items = result.data || [];

                    $.each(items, function (_, item) {
                        rows += '<tr data-id="' + item.id + '">';
                        rows += '<td>' + (item.customDateText || '-') + '</td>';
                        rows += '<td>' + (item.locationName || '-') + '</td>';
                        rows += '<td>' + (item.startTimeText || '-') + '</td>';
                        rows += '<td>' + (item.endTimeText || '-') + '</td>';
                        @if (!Model.IsReadOnly)
                        {
                            <text>
                            rows += '<td class="text-center"><button type="button" class="btn btn-icon-danger btn-delete-custom" data-id="' + item.id + '" title="Delete"><i class="bi bi-trash"></i></button></td>';
                            </text>
                        }
                        rows += '</tr>';
                    });

                    $('#customTimeTable tbody').html(rows || '<tr><td colspan="5" class="text-center text-muted py-4">No custom time table found.</td></tr>');
                }).fail(function () {
                    showCustomTimeError('Failed to load custom time table.');
                });
            }

            $('.employee-toolbar-actions button[type="submit"]').on('click', function () {
                setSubmitMode($(this).data('submit-mode'));
            });

            $('#employeeForm').on('submit', function () {
                setSavingState(true);
            });

            $('.time-table-row').each(function () {
                syncTimeTableRow($(this));
            });

            $('.time-working-check').on('change', function () {
                syncTimeTableRow($(this).closest('tr'));
            });

            $('.duty-roaster-row').each(function () {
                syncDutyRow($(this));
            });

            $('.duty-check').on('change', function () {
                syncDutyRow($(this).closest('tr'));
            });

            $('#contractEndCheckbox').on('change', syncContractEnd);
            syncContractEnd();

            $('#btnReloadRoaster').on('click', function () {
                var action = @((form.Id > 0).ToString().ToLowerInvariant())
                    ? '@Url.Action("Edit", "EmployeeList", new { area = "HR", id = form.Id })'
                    : '@Url.Action("Add", "EmployeeList", new { area = "HR" })';

                var query = '?roasterYear=' + encodeURIComponent($('#RoasterYear').val())
                    + '&roasterMonth=' + encodeURIComponent($('#RoasterMonth').val());

                window.location.href = action + query;
            });

            $('#btnAddCustomTimeTable').on('click', function () {
                showCustomTimeError('');

                var token = $('input[name="__RequestVerificationToken"]').val();
                var employeeId = $('#customEmployeeId').val();
                var payload = {
                    __RequestVerificationToken: token,
                    EmployeeId: employeeId,
                    CustomDate: $('#customDate').val(),
                    LocationId: $('#customLocationId').val(),
                    StartTime: $('#customStartTime').val(),
                    EndTime: $('#customEndTime').val()
                };

                var $button = $(this);
                $button.prop('disabled', true);

                $.post('@Url.Action("AddCustomTimeTableAjax", "EmployeeList", new { area = "HR" })', payload)
                    .done(function (result) {
                        if (!result || result.statusCode !== 200) {
                            showCustomTimeError(result && result.statusMessage ? result.statusMessage : 'Failed to add custom time table.');
                            return;
                        }

                        $('#customDate').val('');
                        $('#customLocationId').val('0');
                        $('#customStartTime').val('');
                        $('#customEndTime').val('');
                        reloadCustomTimeTable();
                    })
                    .fail(function (xhr) {
                        var message = xhr.responseJSON && xhr.responseJSON.statusMessage
                            ? xhr.responseJSON.statusMessage
                            : 'Failed to add custom time table.';
                        showCustomTimeError(message);
                    })
                    .always(function () {
                        $button.prop('disabled', false);
                    });
            });

            $('#customTimeTable').on('click', '.btn-delete-custom', function () {
                if (!confirm('Are you sure you want to delete selected custom time table?')) {
                    return;
                }

                showCustomTimeError('');

                var token = $('input[name="__RequestVerificationToken"]').val();
                var id = $(this).data('id');

                $.post('@Url.Action("DeleteCustomTimeTableAjax", "EmployeeList", new { area = "HR" })', {
                    __RequestVerificationToken: token,
                    id: id
                }).done(function (result) {
                    if (!result || result.statusCode !== 200) {
                        showCustomTimeError(result && result.statusMessage ? result.statusMessage : 'Failed to delete custom time table.');
                        return;
                    }

                    reloadCustomTimeTable();
                }).fail(function (xhr) {
                    var message = xhr.responseJSON && xhr.responseJSON.statusMessage
                        ? xhr.responseJSON.statusMessage
                        : 'Failed to delete custom time table.';
                    showCustomTimeError(message);
                });
            });
        })(jQuery);
    </script>
}

@functions {
    private Microsoft.AspNetCore.Html.IHtmlContent Checkbox(
        string name,
        string label,
        bool value,
        string? disabled,
        string? id = null)
    {
        var checkedText = value ? "checked" : "";
        var disabledText = string.IsNullOrWhiteSpace(disabled) ? "" : "disabled";
        var idAttr = string.IsNullOrWhiteSpace(id) ? "" : $"id=\"{id}\"";

        var html =
            $"<div class=\"employee-check-card\">" +
                $"<div class=\"form-check form-switch\">" +
                    $"<input class=\"form-check-input\" type=\"checkbox\" name=\"{name}\" value=\"true\" {checkedText} {disabledText} {idAttr} />" +
                    $"<input type=\"hidden\" name=\"{name}\" value=\"false\" />" +
                    $"<label class=\"form-check-label\">{label}</label>" +
                $"</div>" +
            $"</div>";

        return new Microsoft.AspNetCore.Html.HtmlString(html);
    }

    private Microsoft.AspNetCore.Html.IHtmlContent Money(
        string name,
        string label,
        decimal value,
        string? disabled)
    {
        var disabledText = string.IsNullOrWhiteSpace(disabled) ? "" : "disabled";

        var html =
            $"<div class=\"col-xl-3 col-md-6\">" +
                $"<label class=\"form-label admin-form-label\">{label}</label>" +
                $"<input type=\"number\" step=\"0.01\" name=\"{name}\" value=\"{value:0.##}\" class=\"form-control\" {disabledText} />" +
            $"</div>";

        return new Microsoft.AspNetCore.Html.HtmlString(html);
    }

    private Microsoft.AspNetCore.Html.IHtmlContent SelectStatic(
        string name,
        string? selectedValue,
        IEnumerable<string> values,
        string? disabled)
    {
        var disabledText = string.IsNullOrWhiteSpace(disabled) ? "" : "disabled";

        var options =
            $"<option value=\"\" {(string.IsNullOrWhiteSpace(selectedValue) ? "selected" : "")}>- Please Select -</option>";

        foreach (var item in values)
        {
            var selected = string.Equals(item, selectedValue, StringComparison.OrdinalIgnoreCase)
                ? "selected"
                : "";

            options += $"<option value=\"{item}\" {selected}>{item}</option>";
        }

        var html =
            $"<select name=\"{name}\" class=\"form-select\" {disabledText}>" +
                options +
            $"</select>";

        return new Microsoft.AspNetCore.Html.HtmlString(html);
    }
}
