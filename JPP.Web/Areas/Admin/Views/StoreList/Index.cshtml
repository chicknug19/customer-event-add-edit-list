@model JPP.Models.Admin.StoreList.Responses.StoreListIndexViewModel

@{
    ViewData["Title"] = "Store List";
    ViewData["PageTitle"] = "Store List";
    ViewData["PageSubtitle"] = "Manage store master data";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div ng-app="storeListApp"
     ng-controller="StoreListController"
     ng-cloak>

    @Html.AntiForgeryToken()

    <div class="admin-page-header mb-4">
        <div>
            <span class="admin-eyebrow">Admin</span>
            <h3>Store List</h3>
            <p>
                Manage store master data including code, location, phone, person in charge, and deleted status.
            </p>
        </div>

        <div class="admin-page-actions">
            <a asp-area="Admin"
               asp-controller="StoreList"
               asp-action="ExportPdf"
               class="btn btn-soft">
                <i class="bi bi-filetype-pdf me-2"></i>
                To PDF
            </a>

            <a asp-area="Admin"
               asp-controller="StoreList"
               asp-action="ExportExcel"
               class="btn btn-soft">
                <i class="bi bi-file-earmark-excel me-2"></i>
                To Excel
            </a>

            <a asp-area="Admin"
               asp-controller="StoreList"
               asp-action="Add"
               class="btn btn-main">
                <i class="bi bi-plus-lg me-2"></i>
                Add
            </a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["InfoMessage"] != null)
    {
        <div class="alert alert-info alert-dismissible fade show" role="alert">
            @TempData["InfoMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="alert alert-success alert-dismissible fade show" role="alert" ng-if="alert.type === 'success'">
        <span ng-bind="alert.message"></span>
        <button type="button" class="btn-close" ng-click="clearAlert()"></button>
    </div>

    <div class="alert alert-danger alert-dismissible fade show" role="alert" ng-if="alert.type === 'danger'">
        <span ng-bind="alert.message"></span>
        <button type="button" class="btn-close" ng-click="clearAlert()"></button>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-xl-4 col-md-6">
            <div class="crm-card stat-card">
                <div class="stat-icon icon-primary">
                    <i class="bi bi-shop"></i>
                </div>
                <h3 ng-bind="summary.totalStore"></h3>
                <p>Total Stores</p>
            </div>
        </div>

        <div class="col-xl-4 col-md-6">
            <div class="crm-card stat-card">
                <div class="stat-icon icon-success">
                    <i class="bi bi-check-circle"></i>
                </div>
                <h3 ng-bind="summary.activeStore"></h3>
                <p>Active Stores</p>
            </div>
        </div>

        <div class="col-xl-4 col-md-6">
            <div class="crm-card stat-card">
                <div class="stat-icon icon-danger">
                    <i class="bi bi-trash3"></i>
                </div>
                <h3 ng-bind="summary.deletedStore"></h3>
                <p>Deleted Stores</p>
            </div>
        </div>
    </div>

    <div class="crm-card mb-4">
        <div class="section-title">
            <h5>Filter Store</h5>
        </div>

        <form ng-submit="searchStores()">
            <div class="row g-3 align-items-end">
                <div class="col-xl-6 col-md-6">
                    <label class="form-label admin-form-label">Keyword</label>
                    <div class="admin-input-icon">
                        <i class="bi bi-search"></i>
                        <input type="text"
                               ng-model="filter.keyword"
                               class="form-control"
                               placeholder="Search by Store ID, code, location, phone, or in charge" />
                    </div>
                </div>

                <div class="col-xl-3 col-md-6">
                    <label class="form-label admin-form-label">Status</label>
                    <select class="form-select" ng-model="filter.status">
                        <option value="All">All</option>
                        <option value="Active">Active</option>
                        <option value="Deleted">Deleted</option>
                    </select>
                </div>

                <div class="col-xl-3 col-md-12 d-flex gap-2">
                    <button type="submit"
                            class="btn btn-main flex-fill"
                            ng-disabled="isBusy()">
                        <i class="bi bi-search me-2"></i>
                        Search
                    </button>

                    <button type="button"
                            class="btn btn-soft"
                            ng-click="resetFilter()"
                            ng-disabled="isBusy()">
                        Reset
                    </button>
                </div>
            </div>
        </form>
    </div>

    <div class="crm-card store-table-card">
        <div class="store-table-header">
            <div>
                <h5>Store Data</h5>
                <p>
                    Showing
                    <span ng-bind="loadedCount"></span>
                    of
                    <span ng-bind="summary.totalStore"></span>
                    store record(s)
                </p>
            </div>

            <button type="button"
                    class="btn btn-soft btn-sm"
                    ng-click="loadStores(true)"
                    ng-disabled="isBusy()">
                <i class="bi bi-arrow-clockwise me-1" ng-class="{ 'store-spin': isBusy() }"></i>
                Refresh
            </button>
        </div>

        <div class="store-table-loading-container">
            <div class="store-loading-overlay" ng-if="isLoading">
                <div class="store-loading-box">
                    <div class="spinner-border text-secondary" role="status"></div>
                    <strong>Loading store data...</strong>
                    <span>Please wait while the table is being updated.</span>
                </div>
            </div>

            <div class="table-responsive store-table-wrapper store-table-scroll"
                 store-infinite-scroll="loadMoreStores()"
                 scroll-disabled="!hasMore || isBusy()">

                <table class="table store-table align-middle">
                    <thead>
                        <tr>
                            <th class="text-center action-col">Action</th>

                            <th class="sortable-th">
                                <button type="button"
                                        class="store-sort-button"
                                        ng-class="{ 'active': isSorted('Id') }"
                                        ng-click="changeSort('Id')">
                                    Store ID
                                    <i class="bi" ng-class="getSortIcon('Id')"></i>
                                </button>
                            </th>

                            <th class="sortable-th">
                                <button type="button"
                                        class="store-sort-button"
                                        ng-class="{ 'active': isSorted('Code') }"
                                        ng-click="changeSort('Code')">
                                    Code
                                    <i class="bi" ng-class="getSortIcon('Code')"></i>
                                </button>
                            </th>

                            <th class="sortable-th">
                                <button type="button"
                                        class="store-sort-button"
                                        ng-class="{ 'active': isSorted('StoreName') }"
                                        ng-click="changeSort('StoreName')">
                                    Location
                                    <i class="bi" ng-class="getSortIcon('StoreName')"></i>
                                </button>
                            </th>

                            <th class="sortable-th">
                                <button type="button"
                                        class="store-sort-button"
                                        ng-class="{ 'active': isSorted('Phone') }"
                                        ng-click="changeSort('Phone')">
                                    Phone
                                    <i class="bi" ng-class="getSortIcon('Phone')"></i>
                                </button>
                            </th>

                            <th class="sortable-th">
                                <button type="button"
                                        class="store-sort-button"
                                        ng-class="{ 'active': isSorted('InChargeName') }"
                                        ng-click="changeSort('InChargeName')">
                                    In Charge
                                    <i class="bi" ng-class="getSortIcon('InChargeName')"></i>
                                </button>
                            </th>

                            <th class="sortable-th">
                                <button type="button"
                                        class="store-sort-button"
                                        ng-class="{ 'active': isSorted('Inactive') }"
                                        ng-click="changeSort('Inactive')">
                                    Deleted
                                    <i class="bi" ng-class="getSortIcon('Inactive')"></i>
                                </button>
                            </th>
                        </tr>
                    </thead>

                    <tbody>
                        <tr ng-repeat="store in stores track by store.id">
                            <td class="text-center action-sticky" data-label="Action">
                                <div class="table-action-icons">
                                    <a ng-href="{{ getDetailUrl(store.id) }}"
                                       class="btn-action-icon btn-view"
                                       title="View">
                                        <i class="bi bi-eye"></i>
                                    </a>

                                    <a ng-href="{{ getEditUrl(store.id) }}"
                                       class="btn-action-icon btn-edit"
                                       title="Edit">
                                        <i class="bi bi-pencil-square"></i>
                                    </a>

                                    <button type="button"
                                            class="btn-action-icon btn-delete"
                                            title="Delete"
                                            ng-if="!store.inactive"
                                            ng-click="openDeleteConfirmation(store)"
                                            ng-disabled="isBusy()">
                                        <i class="bi bi-trash3"></i>
                                    </button>

                                    <button type="button"
                                            class="btn-action-icon btn-disabled"
                                            title="Delete unavailable"
                                            ng-if="store.inactive"
                                            disabled>
                                        <i class="bi bi-trash3"></i>
                                    </button>
                                </div>
                            </td>

                            <td data-label="Store ID">
                                <a ng-href="{{ getDetailUrl(store.id) }}"
                                   class="store-id-link">
                                    #<span ng-bind="store.id"></span>
                                </a>
                            </td>

                            <td data-label="Code">
                                <span class="store-code-badge" ng-bind="store.code || '-'"></span>
                            </td>

                            <td data-label="Location">
                                <div class="store-location-box">
                                    <div class="store-location-icon">
                                        <i class="bi bi-shop"></i>
                                    </div>
                                    <div>
                                        <strong ng-bind="store.storeName || '-'"></strong>
                                        <span>Store Location</span>
                                    </div>
                                </div>
                            </td>

                            <td data-label="Phone">
                                <span class="store-phone" ng-if="store.phone">
                                    <i class="bi bi-telephone me-1"></i>
                                    <span ng-bind="store.phone"></span>
                                </span>

                                <span class="text-muted" ng-if="!store.phone">-</span>
                            </td>

                            <td data-label="In Charge">
                                <div class="store-incharge" ng-if="store.inChargeName">
                                    <span class="store-incharge-avatar" ng-bind="getInitial(store.inChargeName)"></span>
                                    <span ng-bind="store.inChargeName"></span>
                                </div>

                                <span class="text-muted" ng-if="!store.inChargeName">-</span>
                            </td>

                            <td data-label="Deleted">
                                <span class="status-pill status-deleted" ng-if="store.inactive">
                                    <i class="bi bi-trash3 me-1"></i>
                                    Deleted
                                </span>

                                <span class="status-pill status-active" ng-if="!store.inactive">
                                    <i class="bi bi-check-circle me-1"></i>
                                    Active
                                </span>
                            </td>
                        </tr>

                        <tr ng-if="isLoadingMore">
                            <td colspan="7">
                                <div class="store-infinite-loader">
                                    <div class="spinner-border spinner-border-sm text-secondary" role="status"></div>
                                    <span>Loading more stores...</span>
                                </div>
                            </td>
                        </tr>

                        <tr ng-if="!isLoading && !isLoadingMore && stores.length > 0 && !hasMore">
                            <td colspan="7">
                                <div class="store-end-list">
                                    All store data has been loaded.
                                </div>
                            </td>
                        </tr>

                        <tr ng-if="!isLoading && stores.length === 0">
                            <td colspan="7">
                                <div class="admin-empty-state">
                                    <div class="admin-empty-icon">
                                        <i class="bi bi-shop-window"></i>
                                    </div>
                                    <h5>No store data found</h5>
                                    <p>Try changing the keyword or status filter.</p>
                                </div>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="delete-confirm-backdrop"
         ng-if="deleteModal.visible"
         ng-click="closeDeleteConfirmation()">

        <div class="delete-confirm-modal"
             ng-click="$event.stopPropagation()">

            <div class="delete-confirm-header">
                <div class="delete-confirm-icon">
                    <i class="bi bi-trash3"></i>
                </div>

                <div>
                    <h5>Delete Store?</h5>
                    <p>This action will mark the store as deleted.</p>
                </div>

                <button type="button"
                        class="delete-confirm-close"
                        ng-click="closeDeleteConfirmation()"
                        ng-disabled="isDeleting">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>

            <div class="delete-confirm-body">
                <div class="delete-store-preview">
                    <div class="delete-store-avatar">
                        <i class="bi bi-shop"></i>
                    </div>

                    <div class="delete-store-info">
                        <strong ng-bind="deleteModal.store.storeName || '-'"></strong>

                        <div>
                            <span>ID #{{ deleteModal.store.id }}</span>
                            <span ng-if="deleteModal.store.code">
                                Code: {{ deleteModal.store.code }}
                            </span>
                        </div>
                    </div>
                </div>

                <div class="delete-store-detail-grid">
                    <div>
                        <label>Phone</label>
                        <strong ng-bind="deleteModal.store.phone || '-'"></strong>
                    </div>

                    <div>
                        <label>In Charge</label>
                        <strong ng-bind="deleteModal.store.inChargeName || '-'"></strong>
                    </div>
                </div>

                <div class="delete-warning-box">
                    <i class="bi bi-exclamation-triangle"></i>
                    <span>
                        Are you sure you want to delete this store? You can no longer use it as an active store after deletion.
                    </span>
                </div>

                <div class="delete-error-box" ng-if="deleteModal.errorMessage">
                    <i class="bi bi-x-circle"></i>
                    <span ng-bind="deleteModal.errorMessage"></span>
                </div>

            </div>

            <div class="delete-confirm-actions">
                <button type="button"
                        class="btn btn-soft"
                        ng-click="closeDeleteConfirmation()"
                        ng-disabled="isDeleting">
                    Cancel
                </button>

                <button type="button"
                        class="btn btn-delete-confirm"
                        ng-click="confirmDeleteStore()"
                        ng-disabled="isDeleting">
                    <span class="spinner-border spinner-border-sm me-2"
                          ng-if="isDeleting"></span>

                    <i class="bi bi-trash3 me-2"
                       ng-if="!isDeleting"></i>

                    <span ng-if="!isDeleting">Yes, Delete Store</span>
                    <span ng-if="isDeleting">Deleting...</span>
                </button>
            </div>
        </div>
    </div>

</div>

@section Scripts {
    <script>
        window.storeListConfig = {
            getStoreListUrl: '@Url.Action("GetStoreList", "StoreList", new { area = "Admin" })',
            deleteUrl: '@Url.Action("DeleteAjax", "StoreList", new { area = "Admin" })',
            detailUrlTemplate: '@Url.Action("Detail", "StoreList", new { area = "Admin", id = "__id__" })',
            editUrlTemplate: '@Url.Action("Edit", "StoreList", new { area = "Admin", id = "__id__" })',
            initialFilter: {
                keyword: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Keyword)),
                status: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Status)),
                sortColumn: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.SortColumn)),
                sortDirection: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.SortDirection))
                },
            pageSize: @Model.PageSize
        };
    </script>

    <script>
        (function () {
            'use strict';

            angular
                .module('storeListApp', [])
                .directive('storeInfiniteScroll', storeInfiniteScroll)
                .controller('StoreListController', StoreListController);

            storeInfiniteScroll.$inject = ['$parse', '$timeout'];

            function storeInfiniteScroll($parse, $timeout) {
                return {
                    restrict: 'A',
                    link: function (scope, element, attrs) {
                        var callback = $parse(attrs.storeInfiniteScroll);

                        var disabledGetter = attrs.scrollDisabled
                            ? $parse(attrs.scrollDisabled)
                            : null;

                        function onScroll() {
                            if (disabledGetter && disabledGetter(scope)) {
                                return;
                            }

                            var el = element[0];
                            var scrollTop = el.scrollTop;
                            var clientHeight = el.clientHeight;
                            var scrollHeight = el.scrollHeight;
                            var threshold = 140;

                            if (scrollTop + clientHeight >= scrollHeight - threshold) {
                                scope.$applyAsync(function () {
                                    callback(scope);
                                });
                            }
                        }

                        element.on('scroll', onScroll);

                        scope.$on('$destroy', function () {
                            element.off('scroll', onScroll);
                        });

                        $timeout(onScroll, 300);
                    }
                };
            }

            StoreListController.$inject = ['$scope', '$http', '$timeout'];

            function StoreListController($scope, $http, $timeout) {
                var config = window.storeListConfig || {};

                $scope.filter = angular.copy(config.initialFilter || {
                    keyword: '',
                    status: 'All',
                    sortColumn: 'StoreName',
                    sortDirection: 'ASC'
                });

                $scope.sort = {
                    column: $scope.filter.sortColumn || 'StoreName',
                    direction: $scope.filter.sortDirection || 'ASC'
                };

                $scope.stores = [];

                $scope.summary = {
                    totalStore: 0,
                    activeStore: 0,
                    deletedStore: 0
                };

                $scope.page = 1;
                $scope.pageSize = config.pageSize || 20;
                $scope.loadedCount = 0;
                $scope.hasMore = true;

                $scope.isLoading = false;
                $scope.isLoadingMore = false;
                $scope.isDeleting = false;

                $scope.deleteModal = {
                    visible: false,
                    store: null,
                    errorMessage: ''
                };

                $scope.alert = {
                    type: '',
                    message: ''
                };

                $scope.loadStores = loadStores;
                $scope.loadMoreStores = loadMoreStores;
                $scope.searchStores = searchStores;
                $scope.resetFilter = resetFilter;
                $scope.openDeleteConfirmation = openDeleteConfirmation;
                $scope.closeDeleteConfirmation = closeDeleteConfirmation;
                $scope.confirmDeleteStore = confirmDeleteStore;
                $scope.clearAlert = clearAlert;
                $scope.getInitial = getInitial;
                $scope.getDetailUrl = getDetailUrl;
                $scope.getEditUrl = getEditUrl;
                $scope.isBusy = isBusy;

                $scope.changeSort = changeSort;
                $scope.isSorted = isSorted;
                $scope.getSortIcon = getSortIcon;

                loadStores(true);

                function loadStores(reset) {
                    reset = reset === true;

                    if (reset) {
                        $scope.page = 1;
                        $scope.hasMore = true;
                        $scope.loadedCount = 0;
                        $scope.stores = [];
                        $scope.isLoading = true;
                    } else {
                        if (!$scope.hasMore || isBusy()) {
                            return;
                        }

                        $scope.isLoadingMore = true;
                    }

                    return $http.get(config.getStoreListUrl, {
                        params: {
                            Keyword: $scope.filter.keyword || '',
                            Status: $scope.filter.status || 'All',
                            Page: $scope.page,
                            PageSize: $scope.pageSize,
                            SortColumn: $scope.sort.column,
                            SortDirection: $scope.sort.direction
                        }
                    }).then(function (response) {
                        var result = response.data || {};

                        if (result.statusCode !== 200 && result.StatusCode !== 200) {
                            showAlert(
                                'danger',
                                result.statusMessage ||
                                result.StatusMessage ||
                                'Failed to load store data.'
                            );
                            return;
                        }

                        var data = result.data || result.Data || {};
                        var summary = data.summary || data.Summary || {};
                        var pagedStores = data.stores || data.Stores || {};
                        var newStores = pagedStores.items || pagedStores.Items || [];

                        if (reset) {
                            $scope.stores = newStores;
                        } else {
                            Array.prototype.push.apply($scope.stores, newStores);
                        }

                        $scope.summary.totalStore = summary.totalStore || summary.TotalStore || 0;
                        $scope.summary.activeStore = summary.activeStore || summary.ActiveStore || 0;
                        $scope.summary.deletedStore = summary.deletedStore || summary.DeletedStore || 0;

                        $scope.loadedCount =
                            pagedStores.loadedRecords ||
                            pagedStores.LoadedRecords ||
                            $scope.stores.length;

                        $scope.hasMore =
                            pagedStores.hasMore === true ||
                            pagedStores.HasMore === true;

                        if ($scope.hasMore) {
                            $scope.page =
                                (pagedStores.page || pagedStores.Page || $scope.page) + 1;
                        }
                    }).catch(function (error) {
                        if (error.status === 401) {
                            var redirectUrl = error.data && error.data.redirectUrl
                                ? error.data.redirectUrl
                                : '/Account/Login';

                            window.location.href = redirectUrl;
                            return;
                        }

                        var message = getAjaxErrorMessage(error, 'Failed to load store data.');

                        showAlert('danger', message);
                    }).finally(function () {
                        $scope.isLoading = false;
                        $scope.isLoadingMore = false;
                    });
                }

                function loadMoreStores() {
                    return loadStores(false);
                }

                function searchStores() {
                    if (isBusy()) {
                        return;
                    }

                    clearAlert();
                    return loadStores(true);
                }

                function resetFilter() {
                    if (isBusy()) {
                        return;
                    }

                    clearAlert();

                    $scope.filter.keyword = '';
                    $scope.filter.status = 'All';

                    $scope.sort.column = 'StoreName';
                    $scope.sort.direction = 'ASC';

                    return loadStores(true);
                }

                function changeSort(column) {
                    if (isBusy()) {
                        return;
                    }

                    clearAlert();

                    if ($scope.sort.column === column) {
                        $scope.sort.direction = $scope.sort.direction === 'ASC'
                            ? 'DESC'
                            : 'ASC';
                    } else {
                        $scope.sort.column = column;
                        $scope.sort.direction = 'ASC';
                    }

                    return loadStores(true);
                }

                function isSorted(column) {
                    return $scope.sort.column === column;
                }

                function getSortIcon(column) {
                    if (!isSorted(column)) {
                        return 'bi-arrow-down-up';
                    }

                    return $scope.sort.direction === 'ASC'
                        ? 'bi-caret-up-fill'
                        : 'bi-caret-down-fill';
                }

                function openDeleteConfirmation(store) {
                    if (!store || !store.id) {
                        return;
                    }

                    if (store.inactive) {
                        showAlert('danger', 'This store cannot be deleted.');
                        return;
                    }

                    clearAlert();

                    $scope.deleteModal.store = store;
                    $scope.deleteModal.errorMessage = '';
                    $scope.deleteModal.visible = true;
                }

                function closeDeleteConfirmation() {
                    if ($scope.isDeleting) {
                        return;
                    }

                    $scope.deleteModal.visible = false;
                    $scope.deleteModal.store = null;
                    $scope.deleteModal.errorMessage = '';
                }

                function confirmDeleteStore() {
                    var store = $scope.deleteModal.store;

                    if (!store || !store.id) {
                        closeDeleteConfirmation();
                        return;
                    }

                    $scope.isDeleting = true;
                    $scope.deleteModal.errorMessage = '';
                    clearAlert();

                    var tokenElement = document.querySelector('input[name="__RequestVerificationToken"]');
                    var token = tokenElement ? tokenElement.value : '';

                    var body = new URLSearchParams();
                    body.append('id', store.id);

                    return $http.post(config.deleteUrl, body.toString(), {
                        headers: {
                            'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8',
                            'RequestVerificationToken': token
                        }
                    }).then(function (response) {
                        var result = response.data || {};

                        if (result.statusCode !== 200 && result.StatusCode !== 200) {
                            var failedMessage =
                                result.statusMessage ||
                                result.StatusMessage ||
                                'Failed to delete store.';

                            $scope.deleteModal.errorMessage = failedMessage;
                            return;
                        }

                        var successMessage =
                            result.statusMessage ||
                            result.StatusMessage ||
                            'Store has been deleted successfully.';

                        $scope.deleteModal.visible = false;
                        $scope.deleteModal.store = null;
                        $scope.deleteModal.errorMessage = '';

                        return loadStores(true).then(function () {
                            showAlert('success', successMessage);
                        });

                    }).catch(function (error) {
                        if (error.status === 401) {
                            var redirectUrl = error.data && error.data.redirectUrl
                                ? error.data.redirectUrl
                                : '/Account/Login';

                            window.location.href = redirectUrl;
                            return;
                        }

                        var message = getAjaxErrorMessage(error);

                        $scope.deleteModal.errorMessage = message;
                    }).finally(function () {
                        $scope.isDeleting = false;
                    });
                }

                function getAjaxErrorMessage(error) {
                    if (!error) {
                        return 'Failed to delete store.';
                    }

                    if (error.data) {
                        if (error.data.statusMessage) {
                            return error.data.statusMessage;
                        }

                        if (error.data.StatusMessage) {
                            return error.data.StatusMessage;
                        }

                        if (error.data.message) {
                            return error.data.message;
                        }

                        if (typeof error.data === 'string') {
                            return error.data;
                        }
                    }

                    if (error.status === 400) {
                        return 'Invalid request. Failed to delete store.';
                    }

                    if (error.status === 500) {
                        return 'Server error. Failed to delete store.';
                    }

                    return 'Failed to delete store.';
                }

                function isBusy() {
                    return $scope.isLoading || $scope.isLoadingMore || $scope.isDeleting;
                }

                function showAlert(type, message) {
                    $scope.alert.type = type;
                    $scope.alert.message = message;

                    if (type === 'success') {
                        $timeout(function () {
                            clearAlert();
                        }, 3500);
                    }
                }

                function clearAlert() {
                    $scope.alert.type = '';
                    $scope.alert.message = '';
                }

                function getInitial(value) {
                    if (!value) {
                        return '-';
                    }

                    return value.substring(0, 1).toUpperCase();
                }

                function getDetailUrl(id) {
                    return replaceId(config.detailUrlTemplate, id);
                }

                function getEditUrl(id) {
                    return replaceId(config.editUrlTemplate, id);
                }

                function replaceId(template, id) {
                    return (template || '').replace('__id__', encodeURIComponent(id));
                }
            }
        })();
    </script>
}