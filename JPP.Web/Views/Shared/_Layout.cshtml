@{
    var title = ViewData["Title"] ?? "CRM Admin";
}

<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@title</title>

    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />

    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />

    <!-- Google Font -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />

    <!-- Custom CSS -->
    <link href="~/css/app.css" rel="stylesheet" asp-append-version="true" />

    @RenderSection("Styles", required: false)
</head>
<body>

    <div class="crm-wrapper">

        @await Html.PartialAsync("~/Views/Shared/Partials/_Sidebar.cshtml")

        <div class="sidebar-backdrop" id="sidebarBackdrop"></div>

        <main class="crm-main" id="mainContent">

            @await Html.PartialAsync("~/Views/Shared/Partials/_Topbar.cshtml")

            <section class="crm-content">
                @RenderBody()
            </section>

            @await Html.PartialAsync("~/Views/Shared/Partials/_Footer.cshtml")

        </main>

    </div>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    <script src="https://ajax.googleapis.com/ajax/libs/angularjs/1.8.3/angular.min.js"></script>

    <script>
        (function () {
            const btnSidebar = document.getElementById('btnSidebar');
            const sidebar = document.getElementById('sidebar');
            const mainContent = document.getElementById('mainContent');
            const sidebarBackdrop = document.getElementById('sidebarBackdrop');
            const currentYear = document.getElementById('currentYear');

            function isMobile() {
                return window.innerWidth <= 991;
            }

            if (btnSidebar && sidebar && mainContent && sidebarBackdrop) {
                btnSidebar.addEventListener('click', function () {
                    if (isMobile()) {
                        sidebar.classList.toggle('show');
                        sidebarBackdrop.classList.toggle('show');
                    } else {
                        sidebar.classList.toggle('hide');
                        mainContent.classList.toggle('full');
                    }
                });

                sidebarBackdrop.addEventListener('click', function () {
                    sidebar.classList.remove('show');
                    sidebarBackdrop.classList.remove('show');
                });

                window.addEventListener('resize', function () {
                    if (!isMobile()) {
                        sidebar.classList.remove('show');
                        sidebarBackdrop.classList.remove('show');
                    } else {
                        sidebar.classList.remove('hide');
                        mainContent.classList.remove('full');
                    }
                });
            }

            if (currentYear) {
                currentYear.textContent = new Date().getFullYear();
            }
        })();
    </script>

    @RenderSection("Scripts", required: false)

</body>
</html>
